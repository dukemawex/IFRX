# Example environment variables — copy to .env and fill in real values.
# NEVER commit .env to version control.

# TinyFish automation API key (goal-directed web research agent)
# Obtain from: https://agent.tinyfish.ai
TINYFISH_API_KEY=your_tinyfish_api_key_here

# Tavily live web + finance search API key
# Obtain from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# OpenRouter API key (free tier is sufficient)
# Obtain from: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: control research depth (quick | standard | deep)
RESEARCH_DEPTH=deep
